<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="public/styles/style.css" />
  </head>
  <body>
    <div>
      <h1>On this day</h1>
      <p>Search for what happened on this day</p>
      <p>shows wikipedia articles of events that happened on this day</p>

      <form method="post" action="/search" class="form">
        <input type="number" name="month" class="form-date" />
        <input type="number" name="day" class="form-date" />
        <input type="submit" value="submit" class="form-btn" />
      </form>

      <div class="resul">
        <h2>Results:</h2>
        <div class="resul-list">
          <h3 class="resul-title">Titulo</h3>
          <p class="resul-description">
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Quo
            architecto nisi suscipit. Non sunt quod illo, fugiat nostrum itaque.
            Iste dolore libero temporibus modi magni vero eos eveniet,
            consequuntur excepturi?
          </p>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
