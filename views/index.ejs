<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head.ejs") %>
  <body class="vh-100 flex flex-column justify-content-between">
    <div class="container d-flex flex-column align-items-start justify-content center h-100">
      <div class="hero">
        <h1>On this day</h1>
        <p>Search for what happened on this day</p>
        <p>shows wikipedia articles of events that happened on this day</p>
      </div>

      <form method="post" action="/search" class="form">
        <input type="number" name="month" required min="1" max="12" placeholder="month" class="form-date" />
        <input type="number" name="day" required min="1" max="31" placeholder="day" class="form-date" />
        <input type="submit" value="submit" class="form-btn" />
        
        <div class="filters">
          <label for="sort">Sort by:</label>
          <select name="sort">
            <option value="oldest">Oldest</option>
            <option value="newest">Newest</option>
          </select>

          <label for="type">Type:</label>
          <select name="type">
            <option value="events">Events</option>
            <option value="births">Births</option>
            <option value="deaths">Deaths</option>
          </select>
        </div>
      </form>

      <div class="results">
      <% if (locals.date && locals.events) { %>
        <h2>On <%= date %>:</h2>
        <% if (locals.filters) { %>
          <p>(<%= filters.type %>, <%= filters.sort %>)</p>
        <% } %>
        <div class="results-list">
          <% events.forEach((event) => { %>
            <h3 class="results-title"><%= event.year %></h3>
            <% if (typeof event.description !== undefined) { %>
              <p class="results-description">
                <%= event.description %>
              </p>
            <% } %>
            <div>
              <% event.wikipedia.forEach((article) => { %>
                <a href=<%= article.wikipedia %>>
                  <p><%= article.title %></p>
                </a>
              <% }) %>
            </div>
          <% }) %>
        </div>
      <% } else if (locals.date) { %>
        <h2>No results found.</h2>        
      <% } %>
      </div>
    </div>
    <%- include("partials/footer.ejs") %>
  </body>
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"
  ></script>
</html>
